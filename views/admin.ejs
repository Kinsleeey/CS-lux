<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0 maximum-scale=1.0, user-scalable=no">
    <title>CS-Luxury | Admin</title>
    <link rel="stylesheet" href="styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/admin.css" />
</head>
<body>

<div id="toast-container"></div>

<header>
    <div class="main-header">
        <div class="brand">
            <div class="brand-img"></div>
            <p>CS Luxury</p>
        </div>
        <nav>
            <ul class="nav">
                <li><a href="/admin">Dashboard</a></li>
                <li><a href="/product/1">Store</a></li>
                <li><a href="/track-order">Orders</a></li>
            </ul>
        </nav>
        <span class="admin-badge">ADMIN</span>
    </div>
</header>

<div class="admin-layout">

    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <div class="sidebar-item active" onclick="showSection('categories')">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M216,40H40A16,16,0,0,0,24,56V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A16,16,0,0,0,216,40Zm0,160H40V56H216V200ZM184,96a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,96Zm0,32a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,128Zm0,32a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,160Z"/></svg>
            Categories
        </div>
        <div class="sidebar-item" onclick="showSection('products')">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M223.68,66.15,135.68,18a15.88,15.88,0,0,0-15.36,0l-88,48.17a16,16,0,0,0-8.32,14v95.64a16,16,0,0,0,8.32,14l88,48.17a15.88,15.88,0,0,0,15.36,0l88-48.17a16,16,0,0,0,8.32-14V80.18A16,16,0,0,0,223.68,66.15ZM128,32l80.34,44-29.77,16.3-80.35-44ZM128,120,47.66,76l33.9-18.56,80.34,44ZM40,90l80,43.78v85.79L40,175.82Zm96,129.57V133.82L216,90v85.78Z"/></svg>
            Add Product
        </div>
        <div class="sidebar-item" onclick="showSection('orders')">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M222.14,58.87l-96-32a8,8,0,0,0-5.09,0L24,58.87a8,8,0,0,0-5.44,7.56V176a8,8,0,0,0,5.44,7.56l96,32a8,8,0,0,0,5.09,0l96-32A8,8,0,0,0,227.56,176V66.43A8,8,0,0,0,222.14,58.87ZM128,42.93,207.57,69.5,128,96.07,48.43,69.5ZM40,83.63l80,26.67v97.07L40,180.7Zm96,123.74V110.3l80-26.67V180.7Z"/></svg>
            Orders
            <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
                <span class="sidebar-badge"><%= orders.length %></span>
            <% } %>
        </div>
        <div class="sidebar-item" onclick="showSection('stock')">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M240,208H224V96a16,16,0,0,0-16-16H144V40a16,16,0,0,0-24.88-13.26L39.12,72A16,16,0,0,0,32,85.34V208H16a8,8,0,0,0,0,16H240a8,8,0,0,0,0-16ZM208,96V208H144V96ZM48,85.34,128,40V208H48ZM112,112a8,8,0,0,1-8,8H88a8,8,0,0,1,0-16h16A8,8,0,0,1,112,112Zm0,40a8,8,0,0,1-8,8H88a8,8,0,0,1,0-16h16A8,8,0,0,1,112,152Zm0,40a8,8,0,0,1-8,8H88a8,8,0,0,1,0-16h16A8,8,0,0,1,112,192Z"/></svg>
            Stock
            <% if (typeof products !== 'undefined') { %>
                <% const lowCount = products.filter(p => p.stock <= 2).length; %>
                <% if (lowCount > 0) { %>
                    <span class="sidebar-badge"><%= lowCount %></span>
                <% } %>
            <% } %>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">

        <!-- Banner -->
        <div class="welcome-banner">
            <div>
                <h1>Welcome Admin </h1>
                <p>Manage your store, products, and orders from here.</p>
            </div>
            <div class="banner-stats">
                <div class="banner-stat">
                    <p class="stat-num"><%= categories.length %></p>
                    <p class="stat-label">Categories</p>
                </div>
                <div class="banner-stat">
                    <p class="stat-num"><%= orders.length %></p>
                    <p class="stat-label">Orders</p>
                </div>
            </div>
        </div>

        <!-- Categories -->
        <div class="admin-card" id="section-categories">
            <div class="admin-card-header">
                <h4>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M216,40H40A16,16,0,0,0,24,56V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A16,16,0,0,0,216,40Zm0,160H40V56H216V200ZM184,96a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,96Zm0,32a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,128Zm0,32a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,160Z"/></svg>
                    Categories
                </h4>
            </div>
            <div class="admin-card-body">
                <div class="category-list">
                    <% categories.forEach(c => { %>
                        <div class="category-tag">
                            <p><%= c.name %></p>
                            <svg onclick="removeCategory(<%= c.id %>)" style="cursor: pointer;" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="red" viewBox="0 0 256 256"><path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"></path></svg>
                        </div>
                    <% }) %>
                </div>
                <form action="/new-category" method="post" class="category-form">
                    <input type="text" name="category" placeholder="New category name" class="form-input" />
                    <button type="submit" class="btn-primary">Add Category</button>
                </form>
                <% if (msg) { %>
                    <p class="alert-msg"><%= msg %></p>
                <% } %>
            </div>
        </div>

        <!-- Add Product -->
        <div class="admin-card" id="section-products" style="display:none;">
            <div class="admin-card-header">
                <h4>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M223.68,66.15,135.68,18a15.88,15.88,0,0,0-15.36,0l-88,48.17a16,16,0,0,0-8.32,14v95.64a16,16,0,0,0,8.32,14l88,48.17a15.88,15.88,0,0,0,15.36,0l88-48.17a16,16,0,0,0,8.32-14V80.18A16,16,0,0,0,223.68,66.15Z"/></svg>
                    Add New Product
                </h4>
            </div>
            <div class="admin-card-body">
                <form action="/upload" method="post" enctype="multipart/form-data" class="form-stack">
                    <div class="form-group">
                        <label class="form-label">Category</label>
                        <select name="category-id" class="form-input">
                            <option value="">Select a category</option>
                            <% categories.forEach(c => { %>
                                <option value="<%= c.id %>"><%= c.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Product Name</label>
                            <input type="text" name="product-name" class="form-input" placeholder="e.g. Classic Polo Shirt" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Price (₦)</label>
                            <input type="number" name="product-price" class="form-input" placeholder="e.g. 25000" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Description</label>
                        <input type="text" name="product-des" class="form-input" placeholder="Brief product description" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Size Variants</label>
                        <div class="variants-container">
                            <div class="variants-header">
                                <p>Sizes & Stock (optional)</p>
                                <button type="button" class="btn-add-variant" onclick="addRow()">+ Add Size</button>
                            </div>
                            <div id="rows"></div>
                        </div>
                    </div>
                    <div class="form-group" id="single-stock">
                        <label class="form-label">Stock Quantity</label>
                        <input type="number" name="single-stock" class="form-input" placeholder="e.g. 50" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Product Image</label>
                        <div class="image-upload-area">
                            <input type="file" name="product-img" accept="image/*" onchange="previewImage(this)" />
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M213.66,82.34l-56-56A8,8,0,0,0,152,24H56A16,16,0,0,0,40,40V216a16,16,0,0,0,16,16H200a16,16,0,0,0,16-16V88A8,8,0,0,0,213.66,82.34ZM160,51.31,188.69,80H160ZM200,216H56V40h88V88a8,8,0,0,0,8,8h48V216Zm-42.34-61.66a8,8,0,0,1,0,11.32l-24,24a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L120,164.69V120a8,8,0,0,1,16,0v44.69l10.34-10.35A8,8,0,0,1,157.66,154.34Z"/></svg>
                            <p>Click to upload image</p>
                            <span>PNG, JPG up to 10MB</span>
                            <img id="image-preview" src="" alt="Preview" />
                        </div>
                    </div>
                    <button type="submit" class="btn-primary btn-submit">Add to Website</button>
                </form>
            </div>
        </div>

        <!-- Orders -->
        <div class="admin-card" id="section-orders" style="display:none;">
            <div class="admin-card-header">
                <h4>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M222.14,58.87l-96-32a8,8,0,0,0-5.09,0L24,58.87a8,8,0,0,0-5.44,7.56V176a8,8,0,0,0,5.44,7.56l96,32a8,8,0,0,0,5.09,0l96-32A8,8,0,0,0,227.56,176V66.43A8,8,0,0,0,222.14,58.87Z"/></svg>
                    All Orders
                </h4>
                <span class="header-count"><%= orders.length %> total</span>
            </div>
            <div class="admin-card-body">
                <% if (orders.length === 0) { %>
                    <div class="empty-state">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M222.14,58.87l-96-32a8,8,0,0,0-5.09,0L24,58.87A8,8,0,0,0,18.56,66.43V176a8,8,0,0,0,5.44,7.56l96,32a8,8,0,0,0,5.09,0l96-32A8,8,0,0,0,227.44,176V66.43A8,8,0,0,0,222.14,58.87Z"/></svg>
                        <p>No orders yet.</p>
                    </div>
                <% } %>
                <% orders.forEach(order => { %>
                <div class="order-card">
                    <div class="order-card-header">
                        <div class="order-meta">
                            <div class="order-top-row">
                                <span class="order-id">Order #<%= order.id %></span>
                                <span class="status-badge status-<%= order.status %>"><%= order.status %></span>
                            </div>
                            <span class="order-customer"><%= order.first_name || '' %> <%= order.last_name || '' %> — <%= order.email %></span>
                        </div>
                        <div class="order-details-row">
                            <div class="order-detail-item">
                                <span class="detail-label">Date</span>
                                <span class="detail-value"><%= new Date(order.created_at).toDateString() %></span>
                            </div>
                            <div class="order-detail-item">
                                <span class="detail-label">Delivery</span>
                                <span class="detail-value"><%= order.delivery_type %></span>
                            </div>
                            <div class="order-detail-item">
                                <span class="detail-label">Total</span>
                                <span class="detail-value highlight">₦<%= order.total_amount.toLocaleString() %></span>
                            </div>
                        </div>
                        <div class="order-actions">
                            <form action="/admin/order/status" method="POST" class="order-status-form">
                                <input type="hidden" name="order_id" value="<%= order.id %>" />
                                <select name="status" class="status-select">
                                    <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %>>Processing</option>
                                    <option value="shipped"    <%= order.status === 'shipped'    ? 'selected' : '' %>>Shipped</option>
                                    <option value="delivered"  <%= order.status === 'delivered'  ? 'selected' : '' %>>Delivered</option>
                                </select>
                                <button type="submit" class="btn-update">Update</button>
                            </form>
                        </div>
                    </div>
                    <button class="btn-view-items" onclick="toggleOrderList(<%= order.id %>)">View Items</button>
                    <div id="order-list-<%= order.id %>" style="display:none;">
                        <div class="order-items-table">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Size</th>
                                        <th>Qty</th>
                                        <th>Price</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% order.items.forEach(item => { %>
                                    <tr>
                                        <td>
                                            <div class="item-name-cell">
                                                <img src="<%= item.image %>" class="item-img-thumb" alt="<%= item.name %>" />
                                                <span><%= item.name %></span>
                                            </div>
                                        </td>
                                        <td><%= item.size || 'N/A' %></td>
                                        <td><%= item.qty %></td>
                                        <td>₦<%= parseInt(item.price).toLocaleString() %></td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>

        <!-- Stock -->
        <div class="admin-card" id="section-stock" style="display:none;">
            <div class="admin-card-header">
                <h4>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M240,208H224V96a16,16,0,0,0-16-16H144V40a16,16,0,0,0-24.88-13.26L39.12,72A16,16,0,0,0,32,85.34V208H16a8,8,0,0,0,0,16H240a8,8,0,0,0,0-16ZM208,96V208H144V96ZM48,85.34,128,40V208H48ZM112,112a8,8,0,0,1-8,8H88a8,8,0,0,1,0-16h16A8,8,0,0,1,112,112Zm0,40a8,8,0,0,1-8,8H88a8,8,0,0,1,0-16h16A8,8,0,0,1,112,152Zm0,40a8,8,0,0,1-8,8H88a8,8,0,0,1,0-16h16A8,8,0,0,1,112,192Z"/></svg>
                    Stock Overview
                </h4>
                <span class="header-count"><%= typeof products !== 'undefined' ? products.length : 0 %> variants total</span>
            </div>
            <div class="admin-card-body">
                <% if (typeof products !== 'undefined') { %>
                <%
                    const totalVariants = products.length;
                    const lowItems = products.filter(p => p.stock > 0 && p.stock <= 2);
                    const outItems = products.filter(p => p.stock <= 0);
                %>
                <div class="stock-summary-chips">
                    <div class="summary-chip all">
                        <span class="chip-num"><%= totalVariants %></span> Total variants
                    </div>
                    <div class="summary-chip low-chip">
                        <span class="chip-num"><%= lowItems.length %></span> Low stock
                    </div>
                    <div class="summary-chip out-chip">
                        <span class="chip-num"><%= outItems.length %></span> Out of stock
                    </div>
                </div>
                <div class="stock-search-bar">
                    <input type="text" id="stockSearch" class="form-input" placeholder="Search product name..." oninput="filterStock()" />
                    <div class="stock-filter-btns">
                        <button class="filter-btn active-filter" onclick="setFilter('all', this)">All</button>
                        <button class="filter-btn" onclick="setFilter('low', this)">Low stock</button>
                        <button class="filter-btn" onclick="setFilter('out', this)">Out of stock</button>
                    </div>
                </div>
                <div class="stock-table-wrap">
                    <table class="stock-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Size</th>
                                <th>Status</th>
                                <th>Stock level</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="stockBody">
                            <% products.forEach(p => {
                                let statusClass = 'healthy';
                                let statusLabel = p.stock + ' in stock';
                                if (p.stock <= 0) { statusClass = 'out'; statusLabel = 'Out of stock'; }
                                else if (p.stock <= 2) { statusClass = 'low'; statusLabel = p.stock + ' left — low'; }
                                const pct = Math.min(100, Math.round((p.stock / 50) * 100));
                            %>
                            <tr class="stock-row-item" data-name="<%= p.name.toLowerCase() %>" data-status="<%= statusClass %>">
                                <td>
                                    <div class="product-cell">
                                        <img src="<%= p.image %>" alt="<%= p.name %>" class="product-thumb" />
                                        <span class="stock-product-name"><%= p.name %></span>
                                    </div>
                                </td>
                                <td>
                                    <% if (p.size) { %>
                                        <span class="stock-size-badge"><%= p.size %></span>
                                    <% } else { %>
                                        <span class="size-dash">—</span>
                                    <% } %>
                                </td>
                                <td>
                                    <span class="stock-pill <%= statusClass %>">
                                        <span class="stock-pill-dot"></span>
                                        <%= statusLabel %>
                                    </span>
                                </td>
                                <td>
                                    <div class="stock-bar-wrap">
                                        <div class="stock-bar-track">
                                            <div class="stock-bar-fill <%= statusClass %>" style="width:<%= pct %>%"></div>
                                        </div>
                                        <span class="stock-count"><%= p.stock %></span>
                                    </div>
                                </td>
                                <td>
                                    <div class="action-btns">
                                        <button class="btn-icon btn-edit"
                                            data-product-id="<%= p.id %>"
                                            data-variant-id="<%= p.variant_id %>"
                                            data-name="<%= p.name %>"
                                            data-price="<%= p.price %>"
                                            data-stock="<%= p.stock %>"
                                            onclick="editProduct(this.dataset)"
                                            title="Edit">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M227.31,73.37,182.63,28.68a16,16,0,0,0-22.63,0L36.69,152A15.86,15.86,0,0,0,32,163.31V208a16,16,0,0,0,16,16H92.69A15.86,15.86,0,0,0,104,219.31L227.31,96a16,16,0,0,0,0-22.63ZM92.69,208H48V163.31l88-88L180.69,120ZM192,108.68,147.31,64l24-24L216,84.68Z"/></svg>
                                        </button>
                                        <button class="btn-icon btn-delete" onclick="deleteVariant(<%= p.variant_id %>, <%= p.id %>)" title="Delete">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M216,48H176V40a24,24,0,0,0-24-24H104A24,24,0,0,0,80,40v8H40a8,8,0,0,0,0,16h8V208a16,16,0,0,0,16,16H192a16,16,0,0,0,16-16V64h8a8,8,0,0,0,0-16ZM96,40a8,8,0,0,1,8-8h48a8,8,0,0,1,8,8v8H96Zm96,168H64V64H192ZM112,104v64a8,8,0,0,1-16,0V104a8,8,0,0,1,16,0Zm48,0v64a8,8,0,0,1-16,0V104a8,8,0,0,1,16,0Z"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                    <div id="stockEmpty" class="stock-empty" style="display:none;">No products match your filter.</div>
                </div>
                <% } else { %>
                    <div class="stock-empty">No stock data available.</div>
                <% } %>
            </div>
        </div>

    </main>
</div>

<!-- Edit Popup -->
<div id="editOverlay" class="overlay">
    <div class="popup">
        <div class="popup-header">
            <div class="popup-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><path d="M227.31,73.37,182.63,28.68a16,16,0,0,0-22.63,0L36.69,152A15.86,15.86,0,0,0,32,163.31V208a16,16,0,0,0,16,16H92.69A15.86,15.86,0,0,0,104,219.31L227.31,96a16,16,0,0,0,0-22.63Z"/></svg>
                Edit Product
            </div>
            <button class="popup-close" onclick="closeEditPopup()">×</button>
        </div>
        <div class="popup-body">
            <input type="hidden" id="editVariantId" />
            <input type="hidden" id="editProductId" />
            <div class="form-group">
                <label class="form-label">Product Name</label>
                <input id="editProductName" type="text" class="form-input" placeholder="Product name" />
            </div>
            <div class="form-group">
                <label class="form-label">Price (₦)</label>
                <input id="editProductPrice" type="number" class="form-input" placeholder="e.g. 25000" />
            </div>
            <div class="form-group">
                <label class="form-label">Stock</label>
                <input id="editProductStock" type="number" class="form-input" placeholder="e.g. 50" />
            </div>
        </div>
        <div class="popup-footer">
            <button class="btn-ghost" onclick="closeEditPopup()">Cancel</button>
            <button class="btn-save" onclick="patchVariant()">Save Changes</button>
        </div>
    </div>
</div>

<script src="admin.js"></script>
</body>
</html>

