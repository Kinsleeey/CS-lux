<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CS-Luxury</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%2300aaaa'/><text x='50' y='72' font-size='60' font-family='Arial' font-weight='bold' fill='white' text-anchor='middle'>C</text></svg>">
    <link rel="stylesheet" href="/css/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
</head>
<body>
    <div id="page-loader">
        <div class="loader-ring"></div>
    </div>
    <div id="toast-container"></div>
    <header>
        <div class="pre-header flex-sb-c">
            <div class="flex-sb-c gap05">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#ffffff" viewBox="0 0 256 256"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"></path></svg>
                <p>Expect Seasonal discount</p>
            </div>
            <div class="flex-sb-c gap05">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#ffffff" viewBox="0 0 256 256"><path d="M140,180a12,12,0,1,1-12-12A12,12,0,0,1,140,180ZM128,72c-22.06,0-40,16.15-40,36v4a8,8,0,0,0,16,0v-4c0-11,10.77-20,24-20s24,9,24,20-10.77,20-24,20a8,8,0,0,0-8,8v8a8,8,0,0,0,16,0v-.72c18.24-3.35,32-17.9,32-35.28C168,88.15,150.06,72,128,72Zm104,56A104,104,0,1,1,128,24,104.11,104.11,0,0,1,232,128Zm-16,0a88,88,0,1,0-88,88A88.1,88.1,0,0,0,216,128Z"></path></svg>
                <p>Need Help</p>
            </div>
        </div>
        <div class="main-header flex-sb-c">
            
            <div class="brand flex-sb-c gap05">
                <div class="brand-img"></div>
                <p>CS Luxury</p>
            </div>
            <nav>
                <ul class="nav flex-sb-c gap1">
                    <li><a href="/" class="spinner">Home</a></li>
                    <li><a href="/product/1" class="spinner">Product</a></li>
                    <li><a href="/cart" class="spinner">Cart</a></li>
                    <% if (!user) { %>
                        <li><a href="/sign-in" class="spinner">Sign-in</a></li>
                    <% } %>
                </ul>
            </nav>
            <div class="flex-sb-c gap05">
                <!-- Add this where you marked "//space for toggle btn" -->
                
                <div class="whiteback" id="search-toggle" onclick="toggleSearch()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M229.66,218.34l-50.07-50.07a88,88,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.31ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"></path></svg>
                </div>
                <a href="/cart" class="spinner"><div class="whiteback flex-sb-c gap05">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M230.14,58.87A8,8,0,0,0,224,56H62.68L56.6,22.57A8,8,0,0,0,48.73,16H24a8,8,0,0,0,0,16h18L67.56,172.29a24,24,0,0,0,5.33,11.27,28,28,0,1,0,44.4,8.44h45.42A27.75,27.75,0,0,0,160,204a28,28,0,1,0,28-28H91.17a8,8,0,0,1-7.87-6.57L80.13,152h116a24,24,0,0,0,23.61-19.71l12.16-66.86A8,8,0,0,0,230.14,58.87ZM104,204a12,12,0,1,1-12-12A12,12,0,0,1,104,204Zm96,0a12,12,0,1,1-12-12A12,12,0,0,1,200,204Zm4-74.57A8,8,0,0,1,196.1,136H77.22L65.59,72H214.41Z"></path></svg>
                    <p>Cart</p>
                    <div class="greenback"><p id="cart-count">0</p></div>
                </div></a>
                <a href="/wishlist" class="spinner"><div class="whiteback">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M178,40c-20.65,0-38.73,8.88-50,23.89C116.73,48.88,98.65,40,78,40a62.07,62.07,0,0,0-62,62c0,70,103.79,126.66,108.21,129a8,8,0,0,0,7.58,0C136.21,228.66,240,172,240,102A62.07,62.07,0,0,0,178,40ZM128,214.8C109.74,204.16,32,155.69,32,102A46.06,46.06,0,0,1,78,56c19.45,0,35.78,10.36,42.6,27a8,8,0,0,0,14.8,0c6.82-16.67,23.15-27,42.6-27a46.06,46.06,0,0,1,46,46C224,155.61,146.24,204.15,128,214.8Z"></path></svg>
                </div></a>
                <div class="whiteback" id="user-profile">
                    <% if (user) { %>
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M144,157.68a68,68,0,1,0-71.9,0c-20.65,6.76-39.23,19.39-54.17,37.17a8,8,0,0,0,12.25,10.3C50.25,181.19,77.91,168,108,168s57.75,13.19,77.87,37.15a8,8,0,0,0,12.25-10.3C183.18,177.07,164.6,164.44,144,157.68ZM56,100a52,52,0,1,1,52,52A52.06,52.06,0,0,1,56,100Zm197.66,33.66-32,32a8,8,0,0,1-11.32,0l-16-16a8,8,0,0,1,11.32-11.32L216,148.69l26.34-26.35a8,8,0,0,1,11.32,11.32Z"></path></svg>
                    <% } else { %>
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M230.92,212c-15.23-26.33-38.7-45.21-66.09-54.16a72,72,0,1,0-73.66,0C63.78,166.78,40.31,185.66,25.08,212a8,8,0,1,0,13.85,8c18.84-32.56,52.14-52,89.07-52s70.23,19.44,89.07,52a8,8,0,1,0,13.85-8ZM72,96a56,56,0,1,1,56,56A56.06,56.06,0,0,1,72,96Z"></path></svg>
                    <% } %>
                </div>
                <div class="hamburger" id="hamburger" onclick="toggleMobileNav()">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </div>
            

        </div>
        <div class="search-bar" id="search-bar" style="display:none;">
            <div class="search-inner">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 256 256"><path d="M229.66,218.34l-50.07-50.07a88,88,0,1,0-11.31,11.31l50.06,50.07a8,8,0,0,0,11.32-11.31ZM40,112a72,72,0,1,1,72,72A72.08,72.08,0,0,1,40,112Z"></path></svg>
                <input type="text" placeholder="Search for products..." id="search-input" />
                <button onclick="handleSearch()">Search</button>
            </div>
        </div>
        <div class="mobile-nav" id="mobile-nav" onclick="closeMobileNav(event)">
            <div class="mobile-nav-content">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem;">
                    <div class="brand flex-sb-c gap05">
                        <div class="brand-img"></div>
                        <p>CS Luxury</p>
                    </div>
                    <div onclick="toggleMobileNav()" style="cursor:pointer; font-size:1.5rem; color:var(--color-text);">×</div>
                </div>
                <ul style="display:flex; flex-direction:column; gap:0.25rem; list-style:none;">
                    <li><a href="/" class="spinner" style="display:block; padding:0.875rem 1rem; border-radius:var(--radius-sm); font-size:1rem; font-weight:500; color:var(--color-dark); transition:all var(--transition-fast);">Home</a></li>
                    <li><a href="/product/1" class="spinner" style="display:block; padding:0.875rem 1rem; border-radius:var(--radius-sm); font-size:1rem; font-weight:500; color:var(--color-dark); transition:all var(--transition-fast);">Product</a></li>
                    <li><a href="/cart" class="spinner" style="display:block; padding:0.875rem 1rem; border-radius:var(--radius-sm); font-size:1rem; font-weight:500; color:var(--color-dark); transition:all var(--transition-fast);">Cart</a></li>
                    <li><a href="/wishlist" class="spinner" style="display:block; padding:0.875rem 1rem; border-radius:var(--radius-sm); font-size:1rem; font-weight:500; color:var(--color-dark); transition:all var(--transition-fast);">Wishlist</a></li>
                    <li><a href="/track-order" class="spinner" style="display:block; padding:0.875rem 1rem; border-radius:var(--radius-sm); font-size:1rem; font-weight:500; color:var(--color-dark); transition:all var(--transition-fast);">Track Order</a></li>
                    <% if (!user) { %>
                        <li><a href="/sign-in" class="spinner" style="display:block; padding:0.875rem 1rem; border-radius:var(--radius-sm); font-size:1rem; font-weight:500; color:var(--color-dark); transition:all var(--transition-fast);">Sign In</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </header>
    <div class="profile-nav hide">
        <div class="flex-sb-c">
            <div class="flex-c gap1">
                <div class="user-p-pic"></div>
                <h4>Hello Kingsley</h4>
            </div>
            <div id="close-profile">
                <svg style="cursor: pointer;" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#027a84" viewBox="0 0 256 256"><path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"></path></svg>
            </div>
        </div>
        <hr />
        <% if(currentUser.length > 0) { %>

            <div>
                <div class="flex-sb-c">
                    <h4>Personal Details</h4>
                    <a href="/edit-profile" class="spinner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#000000" viewBox="0 0 256 256"><path d="M227.31,73.37,182.63,28.68a16,16,0,0,0-22.63,0L36.69,152A15.86,15.86,0,0,0,32,163.31V208a16,16,0,0,0,16,16H92.69A15.86,15.86,0,0,0,104,219.31L227.31,96a16,16,0,0,0,0-22.63ZM92.69,208H48V163.31l88-88L180.69,120ZM192,108.68,147.31,64l24-24L216,84.68Z"></path></svg>
                    </a>
                </div>
                <div class="inner">
                    <p class="flex-c gap1" >
                        <span class="text-blue">Name:</span>
                        <span >
                            <%- currentUser[0].first_name && currentUser[0].last_name ? currentUser[0].first_name + " " + currentUser[0].last_name : '<a href="/edit-profile" class="center spinner"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#029FAE" viewBox="0 0 256 256"><path d="M208,32H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32Zm0,176H48V48H208V208Zm-32-80a8,8,0,0,1-8,8H136v32a8,8,0,0,1-16,0V136H88a8,8,0,0,1,0-16h32V88a8,8,0,0,1,16,0v32h32A8,8,0,0,1,176,128Z"></path></svg></a>' %>
                        </span>

                    </p>
                    <p class="flex-c gap1" >
                        <span class="text-blue">Email:</span>
                        <span >
                            <%- currentUser[0].email ? currentUser[0].email : '<a href="/edit-profile" class="center spinner"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#029FAE" viewBox="0 0 256 256"><path d="M208,32H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32Zm0,176H48V48H208V208Zm-32-80a8,8,0,0,1-8,8H136v32a8,8,0,0,1-16,0V136H88a8,8,0,0,1,0-16h32V88a8,8,0,0,1,16,0v32h32A8,8,0,0,1,176,128Z"></path></svg></a>' %>
                        </span>
                    </p>
                    <p class="flex-c gap1" >
                        <span class="text-blue">Contact:</span>
                        <span >
                            <%- currentUser[0].phone ? "+234" + " " + currentUser[0].phone : '<a href="/edit-profile" class="center spinner"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#029FAE" viewBox="0 0 256 256"><path d="M208,32H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32Zm0,176H48V48H208V208Zm-32-80a8,8,0,0,1-8,8H136v32a8,8,0,0,1-16,0V136H88a8,8,0,0,1,0-16h32V88a8,8,0,0,1,16,0v32h32A8,8,0,0,1,176,128Z"></path></svg></a>' %>
                        </span>

                    </p>
                </div>
            </div>
            <hr />
            <div>
                <div class="flex-sb-c">
                    <h4>Shipping Address</h4>
                    <a href="/edit-profile">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#000000" viewBox="0 0 256 256"><path d="M227.31,73.37,182.63,28.68a16,16,0,0,0-22.63,0L36.69,152A15.86,15.86,0,0,0,32,163.31V208a16,16,0,0,0,16,16H92.69A15.86,15.86,0,0,0,104,219.31L227.31,96a16,16,0,0,0,0-22.63ZM92.69,208H48V163.31l88-88L180.69,120ZM192,108.68,147.31,64l24-24L216,84.68Z"></path></svg>
                    </a>
                </div>
                <div class="inner">
                    <p class="flex-c gap1" >
                        <span class="text-blue">Country:</span>
                        <span >
                            <%- currentUser[0].country ? currentUser[0].country : '<a href="/edit-profile" class="center spinner"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#029FAE" viewBox="0 0 256 256"><path d="M208,32H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32Zm0,176H48V48H208V208Zm-32-80a8,8,0,0,1-8,8H136v32a8,8,0,0,1-16,0V136H88a8,8,0,0,1,0-16h32V88a8,8,0,0,1,16,0v32h32A8,8,0,0,1,176,128Z"></path></svg></a>' %>
                        </span>
                    </p>
                    <p class="flex-c gap1" >
                        <span class="text-blue">State:</span>
                        <span >
                            <%- currentUser[0].state ? currentUser[0].state : '<a href="/edit-profile" class="center spinner"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#029FAE" viewBox="0 0 256 256"><path d="M208,32H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32Zm0,176H48V48H208V208Zm-32-80a8,8,0,0,1-8,8H136v32a8,8,0,0,1-16,0V136H88a8,8,0,0,1,0-16h32V88a8,8,0,0,1,16,0v32h32A8,8,0,0,1,176,128Z"></path></svg></a>' %>
                        </span>
                    </p>
                    <p class="flex-c gap1" >
                        <span class="text-blue">City:</span>
                        <span >
                            <%- currentUser[0].city ? currentUser[0].city : '<a href="/edit-profile" class="center spinner"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#029FAE" viewBox="0 0 256 256"><path d="M208,32H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32Zm0,176H48V48H208V208Zm-32-80a8,8,0,0,1-8,8H136v32a8,8,0,0,1-16,0V136H88a8,8,0,0,1,0-16h32V88a8,8,0,0,1,16,0v32h32A8,8,0,0,1,176,128Z"></path></svg></a>' %>
                        </span>
                    </p>
                    <p class="flex-c gap1" >
                        <span class="text-blue">Address:</span>
                        <span >
                            <%- currentUser[0].address ? currentUser[0].address : '<a href="/edit-profile" class="center spinner"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#029FAE" viewBox="0 0 256 256"><path d="M208,32H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32Zm0,176H48V48H208V208Zm-32-80a8,8,0,0,1-8,8H136v32a8,8,0,0,1-16,0V136H88a8,8,0,0,1,0-16h32V88a8,8,0,0,1,16,0v32h32A8,8,0,0,1,176,128Z"></path></svg></a>' %>
                        </span>

                    </p>
                </div>
            </div>

        <% } else { %>

            <div>
                <div class="flex-sb-c">
                    <h4>Personal Details</h4>
                    <a href="/sign-in" class="spinner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#000000" viewBox="0 0 256 256"><path d="M208,32H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32Zm0,176H48V48H208V208Zm-32-80a8,8,0,0,1-8,8H136v32a8,8,0,0,1-16,0V136H88a8,8,0,0,1,0-16h32V88a8,8,0,0,1,16,0v32h32A8,8,0,0,1,176,128Z"></path></svg>
                    </a>
                </div>
                <div class="inner">
                    <p><a href="/sign-in" class="spinner">Log-in</a> to view details</p>
                </div>
            </div>
            <hr />
            <div>
                <div class="flex-sb-c">
                    <h4>Shipping Address</h4>
                    <a href="/sign-in" class="spinner">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#000000" viewBox="0 0 256 256"><path d="M208,32H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32Zm0,176H48V48H208V208Zm-32-80a8,8,0,0,1-8,8H136v32a8,8,0,0,1-16,0V136H88a8,8,0,0,1,0-16h32V88a8,8,0,0,1,16,0v32h32A8,8,0,0,1,176,128Z"></path></svg>
                    </a>
                </div>
                <div class="inner">
                    <p><a href="/sign-in" class="spinner">Log-in</a> to view details</p>
                </div>
            </div>

        <% } %>
        <hr />
        <a href="/track-order" class="spinner">Order History</a>
        <hr />
        <a href="/wishlist" class="spinner">My Wishlist</a>
        <hr />
        <a href="/cart" class="spinner">My Cart</a>
        <hr />
        <a href="/edit-profile" class="spinner">Edit Profile</a>
        <hr />
        <a href="/logout" class="spinner">Log out</a>
    </div>

    <script>
        function toggleMobileNav() {
            const nav = document.getElementById('mobile-nav');
            nav.style.display = nav.style.display === 'flex' ? 'none' : 'flex';
            document.body.style.overflow = nav.style.display === 'flex' ? 'hidden' : '';
        }

        function closeMobileNav(e) {
            if (e.target === document.getElementById('mobile-nav')) {
                toggleMobileNav();
            }
        }

    </script>

    


    
    
    
