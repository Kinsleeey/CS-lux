<%- include('partials/header') %>

<section class="cart">
    
    <div class="c-head">
        <h2>Shopping Cart</h2>
        <p>All selected items ready for checkout </p>
    </div>
    <div class="selected-item">
        
        
        <div class="si-cards">
            <% if (cartedProducts.length === 0) { %>
                <h4 class="empty-cart">Cart is empty, add <a href="/product/1">products</a>.</h4>
            <% } %>
            <% for (let cartedProduct of cartedProducts) {%>
                <div class="si-card flex-c">
                    
                    <div class="si-img"><img src="<%= cartedProduct.image %>"/></div>
                    <div class="si-writeup">
                        <span class="si1 flex-sb-c">
                            <p class="name"><%= cartedProduct.name %></p>
                            <button style="border: none; background-color: inherit; color: black; cursor: pointer; " onclick="removeFromCart(<%= cartedProduct.id %>)">X</button>
                        </span>
                        <% if (cartedProduct.size) { %>
                        <span class="ms flex-c">
                            <p class="size">Size: <%= cartedProduct.size %></p>
                        </span>
                        <% } %>
                        <div class="qp flex-c gap1">
                            <div class="flex-sb-c gap05">
                                <button class="xyz-qty-btn" onclick="changeQty(this, -1); cReduceFromCart(<%= cartedProduct.id %>)">-</button>
                                <span class="xyz-qty-value" data-stock="<%= cartedProduct.stock %>"><%= cartedProduct.qty %></span>
                                <button class="xyz-qty-btn" onclick="changeQty(this, 1); cAddToCart(<%= cartedProduct.id %>, 1, <%= cartedProduct.stock %>)">+</button>
                            </div>
                            <p class="product-price">₦<%= Number(cartedProduct.price * cartedProduct.qty).toLocaleString('en-NG') %></p>
                        </div>
                        <span class="av flex-c gap025">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#000000" viewBox="0 0 256 256"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"></path></svg>
                            <p>In stock</p>
                        </span>
                    </div>
                </div>
            <% } %>
        </div>
        <div class="order-sum">
            
            <h4>Order Summary</h4>
            <div class="cal">
                <div class="flex-sb-c">
                    <p>Subtotal</p>
                    <p class="subtotal">₦0</p>
                </div>
                <div class="flex-sb-c">
                    <p>Discount</p>
                    <p>₦0</p>
                </div>
            </div>
            <div class="flex-sb-c">
                <h4>Total</h4>
                <h4 class="total">₦0</h4>
            </div>
            <a href="<%= cartedProducts.length > 0 ? '/checkout' : '#' %>" 
                class="c-button wait" 
                style="<%= cartedProducts.length === 0 ? 'opacity: 0.4; cursor: not-allowed;' : '' %>">
                Checkout
            </a>
            <a href="/product/1" class="c-button wait">continue Shopping</a>
            <div class="pay flex-c gap1">
                <span class="paym flex-c gap025">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#000000" viewBox="0 0 256 256"><path d="M208,80H176V56a48,48,0,0,0-96,0V80H48A16,16,0,0,0,32,96V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V96A16,16,0,0,0,208,80ZM96,56a32,32,0,0,1,64,0V80H96ZM208,208H48V96H208V208Zm-68-56a12,12,0,1,1-12-12A12,12,0,0,1,140,152Z"></path></svg>
                    <p>Secured Payment with:</p>
                </span>
                <div class="paystack">
                    <img src="/image/Paystack Logo Vector.svg .png">
                    <p>Paystack</p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    if (window.location.search.includes('login=true')) {
        document.getElementById('signin-overlay').style.display = 'flex';
    }
</script>

<%- include('partials/footer') %>