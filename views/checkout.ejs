<%- include('partials/header') %>

<section class="checkout">
    <form id="payment-form" action="/payment/initiate" method="POST">
        <div class="check-inner">
            <div class="checkout-info">
                
                <fieldset class="c-edit-body checkout-fieldset">
                    <legend>Personal Details</legend>

                    <div>
                        <p>Name</p>
                        <div class="flex-c gap05">
                            <input type="text" name="first_name" placeholder="First name" value="<%= user.first_name || '' %>"/>
                            <input type="text" name="last_name" placeholder="Last name" value="<%= user.last_name || '' %>"/>
                        </div>
                    </div>

                    <div class="c">
                        <p>Email</p>
                        <input type="text" name="email" value="<%= user.email || '' %>"/>
                    </div>

                    <div>
                        <p>Contact</p>
                        <input type="number" name="phone" value="<%= user.phone || '' %>"/>
                    </div>
                </fieldset>
                
                <fieldset class="shipping-method checkout-fieldset">
                    <legend>Shipping Method</legend>

                    <!-- Pickup at store -->
                    <label class="shipping-label">
                        <div class="shipping-option">
                            <input type="radio" id="pickup" name="delivery_type" value="pickup" />
                            <div class="pm">
                                <span>
                                    <p>Pickup at store</p>
                                    <p>Available at the store upon payment completion</p>
                                </span>
                            </div>
                        </div>
                        <div class="delivery-inner">
                            <p><span class="psha">Store Address:</span> new jerusalem plaza, no.4 makoko avenue, ago palace, lagos.</p>
                        </div>
                    </label>

                    <!-- Delivery Within Lagos -->
                    <label class="shipping-label">
                        <div class="shipping-option">
                            <input type="radio" id="within_lagos" name="delivery_type" value="within_lagos" />
                            <div class="pm">
                                <span>
                                    <p>Delivery within Lagos, Nigeria.</p>
                                    <p>Delivery within 48hrs of purchase</p>
                                </span>
                            </div>
                        </div>
                        <div class="delivery-inner">
                            <p class="psha">Select Pickup</p>
                            <select name="within_lagos_location" id="within_lagos_location">
                                <option value="">-- Select Location --</option>
                                <option>Location1</option>
                                <option>Location2</option>
                                <option>Location3</option>
                                <option>Location4</option>
                                <option>Location5</option>
                                <option>Location6</option>
                            </select>
                        </div>
                    </label>

                    <!-- Delivery Outside Lagos -->
                    <label class="shipping-label">
                        <div class="shipping-option">
                            <input type="radio" id="outside_lagos" name="delivery_type" value="outside_lagos"/>
                            <div class="pm">
                                <span>
                                    <p>Delivery Outside Lagos, Nigeria.</p>
                                    <p>Available at the store upon payment completion.</p>
                                </span>
                            </div>
                        </div>
                        <div class="delivery-inner">
                            <div class="user-address" style="border: none; padding: 0;">
                                <p class="psha">Shipping Address</p>
                                <div class="flex-sb-c">
                                    <div>
                                        <label for="country">Country</label>
                                        <input type="text" id="country" name="country" value="<%= user.country || '' %>"/>
                                    </div>
                                    <div>
                                        <label for="state">State</label>
                                        <input type="text" id="state" name="state" value="<%= user.state || '' %>"/>
                                    </div>
                                    <div>
                                        <label for="city">City</label>
                                        <input type="text" id="city" name="city" value="<%= user.city || '' %>"/>
                                    </div>
                                </div>
                                <div>
                                    <label for="address">Address</label>
                                    <input type="text" id="address" name="address" placeholder="street, no" value="<%= user.address || '' %>"/>
                                </div>
                                <div class="checkbox-row">
                                    <input type="checkbox" id="is_save" name="is_save"/>
                                    <p>Update address as your profile shipping address</p>
                                </div>
                            </div>
                        </div>
                    </label>

                </fieldset>
                
            </div>

            

            <div class="order-sum">
                <h4>Order Summary</h4>
                <div class="cal">
                    <div class="summary-row">
                        <p>Subtotal</p>
                        <p>₦<%= Number(subtotal).toLocaleString('en-NG') %></p>
                    </div>
                    <div class="summary-row">
                        <p>Shipping Fee</p>
                        <p>₦<%= Number(shippingFee).toLocaleString('en-NG') %></p>
                    </div>
                </div>
                <div class="summary-total">
                    <h4>Total</h4>
                    <h4>₦<%= Number(total).toLocaleString('en-NG') %></h4>
                </div>
                <button type="submit" class="c-button wait">Confirm Order</button>
                <a href="/cart" class="c-button wait">Back to cart</a>
            </div>
        </div>
    </form>
</section>

<script>
    document.querySelectorAll('.shipping-label input[type="radio"]').forEach(function(radio) {
    radio.addEventListener('change', function() {
        // hide all delivery-inner divs first
        document.querySelectorAll('.shipping-label .delivery-inner').forEach(function(inner) {
            inner.style.display = 'none';
        });

        // show only the one inside the selected label
        var selectedInner = this.closest('.shipping-label').querySelector('.delivery-inner');
        if (selectedInner) {
            selectedInner.style.display = 'flex';
        }
    });
});

// show the default checked one on page load
var defaultChecked = document.querySelector('.shipping-label input[type="radio"]:checked');
if (defaultChecked) {
    var defaultInner = defaultChecked.closest('.shipping-label').querySelector('.delivery-inner');
    if (defaultInner) defaultInner.style.display = 'flex';
}
</script>


<%- include('partials/footer') %>